@model SistemaAdm.ViewModel.CadastroModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/cadUser.css" asp-append-version="true" />
</head>

<body>
    <header class="d-flex align-items-center justify-content-between px-4 py-3 header-conteiner gap-4">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-hexagon-fill text-dark fs-4"></i>
            <span class="fs-5"><strong>Axis-Management</strong></span>
        </div>
        <div class="text-center">
            <h1 class="fw-bold fs-4 mb-0">Cadastro da Empresa</h1>
            <p class="text-dark small mb-0 opacity-75">Configure sua empresa para começar a utilizar o sistema.</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-dark btn-sm rounded-pill" disabled>
                <i class="bi bi-moon-stars"></i> Tema
            </button>
            <button type="button" class="btn btn-outline-dark btn-sm rounded-pill" disabled>
                <i class="bi bi-globe2"></i> Idioma
            </button>
        </div>
    </header>
    <main class="conteiner">
        <div class="card-header">
            <ul class="nav nav-tabs card-header-tabs" id="empresaTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="tab-dados-principais" data-bs-toggle="tab"
                            data-bs-target="#pane-dados-principais" type="button" role="tab">
                        Dados Principais
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-endereco" data-bs-toggle="tab" data-bs-target="#pane-endereco"
                            type="button" role="tab">
                        Endereço
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-contatos" data-bs-toggle="tab" data-bs-target="#pane-contatos"
                            type="button" role="tab">
                        Contatos
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-responsavel" data-bs-toggle="tab"
                            data-bs-target="#pane-responsavel" type="button" role="tab">
                        Responsável
                    </button>
                </li>
            </ul>
        </div>
        <div class="card-body">
            <div class="row mt-2">
                <div class="col-12 col-md-8">
                    <div class="tab-content" id="empresaTabContent">
                        <div class="tab-pane fade show active" id="pane-dados-principais" role="tabpanel">
                            <div class="row g-3">
                                <div class="col-12 col-md-8">
                                    <label for="RazaoSocial" class="form-label">
                                        Razão Social <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" class="form-control" id="RazaoSocial" name="RazaoSocial" required
                                           placeholder="Ex: Comercial Alfa Ltda" />
                                </div>
                                <div class="col-12 col-md-4">
                                    <label for="CNPJ" class="form-label">
                                        CNPJ <span class="text-danger">*</span>
                                    </label>

                                    <input type="text" class="form-control" id="CNPJ" name="CNPJ" required
                                           placeholder="00.000.000/0000-00" maxlength="18" />
                                </div>
                                <div class="col-12 col-md-8">
                                    <label for="NomeFantasia" class="form-label">
                                        Nome Fantasia
                                    </label>
                                    <input type="text input-camp " class="form-control" id="NomeFantasia" name="NomeFantasia"
                                           placeholder="Ex: Alfa Distribuidora" />
                                </div>
                                <div class="col-12 col-md-4">
                                    <label for="DataFundacao" class="form-label">
                                        Data de Fundação
                                    </label>
                                    <input type="date input-camp " class="form-control" id="DataFundacao" name="DataFundacao" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label for="Situacao" class="form-label">
                                        Situação
                                    </label>
                                    <select class="form-select input-camp" id="Situacao" name="Situacao">

                                        <option value="Ativa" selected>Ativa</option>
                                        <option value="Inativa">Inativa</option>
                                        <option value="Suspensa">Suspensa</option>
                                        <option value="EmAnalise">Em análise</option>

                                    </select>
                                </div>
                                <div class="col-12 col-md-6">
                                    <label for="Site" class="form-label">
                                        Site
                                    </label>
                                    <input type="url" class="form-control" id="Site" name="Site"
                                           placeholder="https://www.suaempresa.com.br" />
                                </div>
                                <div class="col-12">
                                    <label for="Observacoes" class="form-label">
                                        Observações
                                    </label>
                                    <textarea class="form-control input-camp" id="Observacoes" name="Observacoes" rows="3"
                                              placeholder="Informações adicionais sobre a empresa"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="pane-endereco" role="tabpanel"
                             aria-activedescendant="tab-endereco">
                            <div class="row g-3">
                                <div class="col-12 col col-md-8">
                                    @Html.LabelFor(m => m.CPFJ, new { @class = "form-label" })
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="pane-contatos" role="tabpanel"
                             aria-activedescendant="tab-contatos">
                            <div class="row g-3">
                                <div class="col-12 col col-md-8">
                                    @Html.LabelFor(m => m.CPFJ, new { @class = "form-label" })
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="pane-responsavel" role="tabpanel"
                             aria-activedescendant="tab-responsavel">
                            <div class="row g-3">
                                <div class="col-12 col col-md-8">
                                    @Html.LabelFor(m => m.CPFJ, new { @class = "form-label" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4 border-start">
                    <div class="text-center">
                        <label class="form-label d-block text-start">
                            Logo da empresa
                        </label>
                        <div class="border rounded d-flex align-items-center justify-content-center bg-light mx-auto mb-3"
                             style="width:180px;height:180px;overflow:hidden;">
                            <img id="LogoPreview" src="" class="d-none"
                                 style="width:100%;height:100%;object-fit:contain;" />

                            <i id="LogoIcon" class="bi bi-building text-secondary" style="font-size:3rem;">
                            </i>
                        </div>
                        <p class="text-muted small mb-3">
                            PNG • JPG • WEBP<br />
                            Máximo 5MB
                        </p>
                        <label for="LogoFile" class="btn btn-outline-primary w-100">
                            <i class="bi bi-upload"></i>
                            Selecionar Logo
                        </label>
                        <input type="file" id="LogoFile" name="LogoFile" accept=".png,.jpg,.jpeg,.webp"
                               class="d-none" />
                    </div>
                </div>
            </div>
            <div class="row mt-3 justify-content-center">
                <div class="col text-center">
                    <a asp-controller="Login" asp-action="Index" class="btn btn-secondary">
                        Voltar
                    </a>
                    <button type="submit" class="btn btn-success ms-2">
                        Cadastrar
                    </button>
                </div>
            </div>
        </div>
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/cadUser.js" asp-append-version="true"></script>
</body>

</html>
