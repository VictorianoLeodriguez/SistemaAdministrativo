@model SistemaAdm.ViewModel.CadastroModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/cadUser.css" asp-append-version="true" />
</head>

<body>
    <header class="d-flex align-items-center justify-content-between px-4 py-3 header-conteiner gap-4">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-hexagon-fill text-dark fs-4"></i>
            <span class="fs-5"><strong>Axis-Management</strong></span>
        </div>
        <div class="text-center">
            <h1 class="fw-bold fs-4 mb-0">Cadastro da Empresa</h1>
            <p class="text-dark small mb-0 opacity-75">Configure sua empresa para começar a utilizar o sistema.</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-dark btn-sm rounded-pill" disabled>
                <i class="bi bi-moon-stars"></i>
            </button>
            <button type="button" class="btn btn-outline-dark btn-sm rounded-pill" disabled>
                <i class="bi bi-globe2"></i>
            </button>
        </div>
    </header>
    <main class="conteiner">
        <div class="card-header">
            <ul class="nav nav-tabs card-header-tabs" id="empresaTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="tab-dados-principais" data-bs-toggle="tab"
                            data-bs-target="#pane-dados-principais" type="button" role="tab">
                        Dados Principais
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-endereco" data-bs-toggle="tab" data-bs-target="#pane-endereco"
                            type="button" role="tab">
                        Endereço
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-contatos" data-bs-toggle="tab" data-bs-target="#pane-contatos"
                            type="button" role="tab">
                        Contatos
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-responsavel" data-bs-toggle="tab"
                            data-bs-target="#pane-responsavel" type="button" role="tab">
                        Responsável
                    </button>
                </li>
            </ul>
        </div>
        @using (Html.BeginForm("SalvarUser", "Cadastro", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="card-body">
                <div class="row mt-2">
                    <div class="col-12 col-md-8">
                        <div class="tab-content" id="empresaTabContent">
                            <div class="tab-pane fade show active" id="pane-dados-principais" role="tabpanel">
                                <div class="row g-3">
                                    <div class="col-12 col-md-8">
                                        @Html.LabelFor(m => m.RazaoSocial, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.RazaoSocial, new
                                        {
                                            @class = "input-camp  form-control",
                                            placeholder = "Ex: Exemplo Ltda"
                                        })
                                        @Html.ValidationMessageFor(m => m.RazaoSocial, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-4">
                                        @Html.LabelFor(m => m.CNPJ, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.CNPJ, new
                                        {
                                            @class = "input-camp form-control",
                                            placeholder
                                        = "00.000.000/0000-00",
                                            maxlength = "18"
                                        })
                                        @Html.ValidationMessageFor(m => m.CNPJ, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-8">
                                        @Html.LabelFor(m => m.NomeFantasia, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.NomeFantasia, new
                                        {
                                            @class = "input-camp form-control",
                                            placeholder = "Ex: Alfa Distribuidora"
                                        })
                                        @Html.ValidationMessageFor(m => m.NomeFantasia, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-4">
                                        @Html.LabelFor(m => m.DataFundacao, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.DataFundacao, "{0:yyyy-MM-dd}", new { @class = "input-camp  form-control", type = "date", data_val_date = "Data de Fundação inválida", data_val_required = "O Campo Data de Fundação é Obrigatório" })
                                        @Html.ValidationMessageFor(m => m.DataFundacao, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.Site, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.Site, new
                                        {
                                            @class = "input-camp form-control",
                                            type ="url",
                                            placeholder = "https://www.suaempresa.com.br"
                                        })
                                        @Html.ValidationMessageFor(m => m.Site, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="pane-endereco" role="tabpanel"
                                 aria-activedescendant="tab-endereco">
                                <div class="row g-3">
                                    <div class="col-12 col-md-4">
                                        @Html.LabelFor(m => m.CEP, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.CEP, new
                                        {
                                            @class = "input-camp form-control",
                                            placeholder ="00000-000"
                                        })
                                        @Html.ValidationMessageFor(m => m.CEP, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-8">
                                        @Html.LabelFor(m => m.Logradouro, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.Logradouro, new { @class = "input-camp form-control" })
                                        @Html.ValidationMessageFor(m => m.Logradouro, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-4">
                                        @Html.LabelFor(m => m.Numero, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.Numero, new { @class = "input-camp form-control" })
                                        @Html.ValidationMessageFor(m => m.Numero, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-8">
                                        @Html.LabelFor(m => m.Complemento, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.Complemento, new { @class = "input-camp form-control" })
                                        @Html.ValidationMessageFor(m => m.Complemento, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.Bairro, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.Bairro, new { @class = "input-camp form-control" })
                                        @Html.ValidationMessageFor(m => m.Bairro, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.Cidade, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.Cidade, new { @class = "input-camp form-control" })
                                        @Html.ValidationMessageFor(m => m.Cidade, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-4">
                                        @Html.LabelFor(m => m.Estado, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.Estado, new
                                        {
                                            @class = "input-camp form-control",
                                            maxlength
                                        = "2"
                                        })
                                        @Html.ValidationMessageFor(m => m.Estado, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="pane-contatos" role="tabpanel"
                                 aria-activedescendant="tab-contatos">
                                <div class="row g-3">
                                    <div class="col-12 col-md-8">
                                        @Html.LabelFor(m => m.Email, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.Email, new
                                        {
                                            @class = "input-camp form-control",
                                            type = "email",
                                            placeholder = "contato@suaempresa.com.br"
                                        })
                                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.Telefone, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.Telefone, new { @class = "form-control", placeholder = "(00) 0000-0000" })
                                        @Html.ValidationMessageFor(m => m.Telefone, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.Celular, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.Celular, new
                                        {
                                            @class = "input-camp form-control",
                                            placeholder = "(00) 00000-0000"
                                        })
                                        @Html.ValidationMessageFor(m => m.Celular, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="pane-responsavel" role="tabpanel"
                                 aria-activedescendant="tab-responsavel">
                                <div class="row g-3">
                                    <div class="col-12 col-md-8">
                                        @Html.LabelFor(m => m.NomeResponsavel, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.TextBoxFor(m => m.NomeResponsavel, new { @class = "input-camp form-control" })
                                        @Html.ValidationMessageFor(m => m.NomeResponsavel, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.Senha, new { @class = "form-label" }) <span
                                        class="text-danger">*</span>
                                        @Html.PasswordFor(m => m.Senha, new { @class = "input-camp form-control" })
                                        @Html.ValidationMessageFor(m => m.Senha, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4 border-start">
                        <div class="text-center">
                            <label class="form-label d-block text-start">
                                Logo da empresa
                            </label>
                            <div class="border rounded d-flex align-items-center justify-content-center bg-light mx-auto mb-3"
                                 style="width:180px;height:180px;overflow:hidden;">
                                <img id="LogoPreview" src="" class="d-none"
                                     style="width:100%;height:100%;object-fit:contain;" />

                                <i id="LogoIcon" class="bi bi-building text-secondary" style="font-size:3rem;">
                                </i>
                            </div>
                            <p class="text-muted small mb-3">
                                PNG • JPG • WEBP<br />
                                Máximo 5MB
                            </p>
                            <label for="LogoFile" class="btn btn-outline-primary w-100">
                                <i class="bi bi-upload"></i>
                                Selecionar Logo
                            </label>
                            <input type="file" id="LogoFile" name="LogoFile" accept=".png,.jpg,.jpeg,.webp"
                                   class="d-none" />
                        </div>
                    </div>
                </div>
                <div class="row mt-3 justify-content-center">
                    <div class="col text-center">
                        <a asp-controller="Login" asp-action="Index" class="btn btn-secondary">
                            Voltar
                        </a>
                        <button type="submit" id="btnCadastrar" class="btn btn-success ms-2">
                            Cadastrar
                        </button>
                    </div>
                </div>
            </div>
        }
    </main>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/cadUser.js" asp-append-version="true"></script>
</body>

</html>
