<!DOCTYPE html>
<html lang="pt-br">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet"href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">   
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
</head>
<body>
    <aside class="sidebar closed" id="sidebar">
        <div class="sidebar-header">
            <button id="btnSidebar">
                <i class="bi bi-list"></i>
            </button>
            <span class="logo-text">
                Axis-Management
            </span>
    </div>
    <ul class="sidebar-menu"> 
        <li>
            <a asp-controller="Home" asp-action="Index" class="inicio">
                <i class="bi bi-house-door"></i>
                <span>Início</span>
            </a>
        </li>
        <li class="menu-group">
            <button class="menu-toggle" data-bs-toggle="collapse" data-bs-target="#menuRh" aria-expanded="false">
                <div>
                    <i class="bi bi-people"></i>
                    <span>RH</span>
                </div>
                <i class="bi bi-chevron-down arrow"></i>
            </button>
            <div class="collapse" id="menuRh">
                <a href="#">Funcionários</a>
                <a href="#">Cargos</a>
                <a href="#">Departamentos</a>
                <a href="#">Férias</a>
                <a href="#">Benefícios</a>
            </div>
        </li>
        <li class="menu-group">
            <button class="menu-toggle" data-bs-toggle="collapse" data-bs-target="#menuFin" aria-expanded="false">
                <div>
                    <i class="bi bi-cash-stack"></i>
                    <span>Financeiro</span>
                </div>
                <i class="bi bi-chevron-down arrow"></i>
            </button>
            <div class="collapse" id="menuFin">
                <a href="#">Contas a Receber</a>
                <a href="#">Contas a Pagar</a>
                <a href="#">Fluxo de Caixa</a>
                <a href="#">Bancos</a>
            </div>
        </li>
        <li class="menu-group">
            <button class="menu-toggle" data-bs-toggle="collapse" data-bs-target="#menuProd" aria-expanded="false">
                <div>
                    <i class="bi bi-box-seam"></i>
                    <span>Produtos</span>
                </div>
                <i class="bi bi-chevron-down arrow"></i>
            </button>
            <div class="collapse" id="menuProd">
                <a href="#">Produtos</a>
                <a href="#">Categorias</a>
                <a href="#">Marcas</a>
                <a href="#">Estoque</a>
            </div>
        </li>
        <li class="menu-group">
            <button class="menu-toggle" data-bs-toggle="collapse" data-bs-target="#menuAdm" aria-expanded="false">
                <div>
                    <i class="bi bi-gear"></i>
                    <span>Administração</span>
                </div>
                <i class="bi bi-chevron-down arrow"></i>
            </button>
            <div class="collapse" id="menuAdm">
                <a href="#">Usuários</a>
                <a href="#">Perfis</a>
                <a href="#">Permissões</a>
                <a href="#">Auditoria</a>
            </div>
        </li>
    </ul>
     <div class="sidebar-footer">
    <form asp-controller="Login" asp-action="LogOut" method="post">
        @Html.AntiForgeryToken()
        <button type="submit">
            <i class="bi bi-box-arrow-right"></i>
            <span>Sair</span>
        </button>
    </form>
</div>
    </aside>
    <main class="content expanded">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        $(document).on("click", "#btnSidebar", function () {
            $("#sidebar").toggleClass("closed");
            $(".content").toggleClass("expanded");

            if ($("#sidebar").hasClass("closed")) {
                $("#sidebar .menu-toggle").attr("aria-expanded", "false");
            }
            else{
                $("#sidebar .menu-toggle").attr("data-bs-toggle", "collapse");
            }
        });

    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>