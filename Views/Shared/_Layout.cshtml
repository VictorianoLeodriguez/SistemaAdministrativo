<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SistemaAdm - Layout</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/SistemaAdm.styles.css" asp-append-version="true" />
</head>
<body> 

    <!-- ========================================================
         OVERLAY: fecha o menu no mobile ao clicar fora
    ======================================================== -->
    <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>

    <!-- ========================================================
         SIDEBAR
    ======================================================== -->
    <aside class="sidebar" id="sidebar" role="navigation" aria-label="Menu principal">

        <!-- Cabeçalho da sidebar -->
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <span class="sidebar-logo-icon" aria-hidden="true">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                </span>
                <span class="sidebar-logo-text">SistemaAdm</span>
            </div>
            <button class="sidebar-close-btn" id="sidebarCloseBtn" aria-label="Fechar menu">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
            </button>
        </div>

        <!-- Informações do usuário logado -->
        <div class="sidebar-user">
            <div class="sidebar-user-avatar" aria-hidden="true">VA</div>
            <div class="sidebar-user-info">
                <span class="sidebar-user-name">Victoriano A.</span>
                <span class="sidebar-user-role">Administrador</span>
            </div>
        </div>

        <!-- Navegação principal -->
        <nav class="sidebar-nav" aria-label="Navegação">
            <ul class="sidebar-menu" role="list">

                <!-- Dashboard -->
                <li class="sidebar-item">
                    <a class="sidebar-link active" href="/Dashboard" aria-current="page">
                        <i class="bi bi-speedometer2 sidebar-link-icon" aria-hidden="true"></i>
                        <span class="sidebar-link-text">Dashboard</span>
                    </a>
                </li>

                <!-- Grupo: Cadastros (com submenu) -->
                <li class="sidebar-item sidebar-item--has-submenu">
                    <button class="sidebar-link sidebar-link--submenu-toggle"
                            aria-expanded="false"
                            aria-controls="submenu-cadastros"
                            type="button">
                        <i class="bi bi-people sidebar-link-icon" aria-hidden="true"></i>
                        <span class="sidebar-link-text">Cadastros</span>
                        <i class="bi bi-chevron-down sidebar-link-arrow" aria-hidden="true"></i>
                    </button>
                    <ul class="sidebar-submenu" id="submenu-cadastros" role="list" hidden>
                        <li class="sidebar-subitem">
                            <a class="sidebar-sublink" href="/Usuarios">
                                <i class="bi bi-person sidebar-sublink-icon" aria-hidden="true"></i>
                                Usuários
                            </a>
                        </li>
                        <li class="sidebar-subitem">
                            <a class="sidebar-sublink" href="/Clientes">
                                <i class="bi bi-person-badge sidebar-sublink-icon" aria-hidden="true"></i>
                                Clientes
                            </a>
                        </li>
                        <li class="sidebar-subitem">
                            <a class="sidebar-sublink" href="/Fornecedores">
                                <i class="bi bi-truck sidebar-sublink-icon" aria-hidden="true"></i>
                                Fornecedores
                            </a>
                        </li>
                    </ul>
                </li>

                <!-- Produtos -->
                <li class="sidebar-item">
                    <a class="sidebar-link" href="/Produtos">
                        <i class="bi bi-box-seam sidebar-link-icon" aria-hidden="true"></i>
                        <span class="sidebar-link-text">Produtos</span>
                    </a>
                </li>

                <!-- Financeiro -->
                <li class="sidebar-item">
                    <a class="sidebar-link" href="/Financeiro">
                        <i class="bi bi-cash-stack sidebar-link-icon" aria-hidden="true"></i>
                        <span class="sidebar-link-text">Financeiro</span>
                    </a>
                </li>

                <!-- Grupo: Relatórios (com submenu) -->
                <li class="sidebar-item sidebar-item--has-submenu">
                    <button class="sidebar-link sidebar-link--submenu-toggle"
                            aria-expanded="false"
                            aria-controls="submenu-relatorios"
                            type="button">
                        <i class="bi bi-bar-chart-line sidebar-link-icon" aria-hidden="true"></i>
                        <span class="sidebar-link-text">Relatórios</span>
                        <i class="bi bi-chevron-down sidebar-link-arrow" aria-hidden="true"></i>
                    </button>
                    <ul class="sidebar-submenu" id="submenu-relatorios" role="list" hidden>
                        <li class="sidebar-subitem">
                            <a class="sidebar-sublink" href="/Relatorios/Vendas">
                                <i class="bi bi-graph-up sidebar-sublink-icon" aria-hidden="true"></i>
                                Vendas
                            </a>
                        </li>
                        <li class="sidebar-subitem">
                            <a class="sidebar-sublink" href="/Relatorios/Estoque">
                                <i class="bi bi-archive sidebar-sublink-icon" aria-hidden="true"></i>
                                Estoque
                            </a>
                        </li>
                        <li class="sidebar-subitem">
                            <a class="sidebar-sublink" href="/Relatorios/Caixa">
                                <i class="bi bi-wallet2 sidebar-sublink-icon" aria-hidden="true"></i>
                                Caixa
                            </a>
                        </li>
                    </ul>
                </li>

                <!-- Configurações -->
                <li class="sidebar-item">
                    <a class="sidebar-link" href="/Configuracoes">
                        <i class="bi bi-gear sidebar-link-icon" aria-hidden="true"></i>
                        <span class="sidebar-link-text">Configurações</span>
                    </a>
                </li>

            </ul>
        </nav>

        <!-- Rodapé da sidebar: Sair -->
        <div class="sidebar-footer">
            <a class="sidebar-link sidebar-link--danger" href="/Account/Logout">
                <i class="bi bi-box-arrow-left sidebar-link-icon" aria-hidden="true"></i>
                <span class="sidebar-link-text">Sair</span>
            </a>
        </div>

    </aside>

    <!-- ========================================================
         ÁREA PRINCIPAL
    ======================================================== -->
    <div class="layout-wrapper">

        <!-- Topbar -->
        <header class="topbar" role="banner">
            <button class="topbar-toggle" id="sidebarToggleBtn" aria-label="Abrir menu" aria-expanded="false" aria-controls="sidebar">
                <i class="bi bi-list" aria-hidden="true"></i>
            </button>
            <div class="topbar-breadcrumb">
                <span>Dashboard</span>
            </div>
            <div class="topbar-actions">
                <button class="topbar-action-btn" aria-label="Notificações">
                    <i class="bi bi-bell" aria-hidden="true"></i>
                    <span class="topbar-badge" aria-label="3 notificações">3</span>
                </button>
                <div class="topbar-user-avatar" aria-hidden="true">VA</div>
            </div>
        </header>

        <!-- Conteúdo da página -->
        <main class="main-content" id="mainContent" role="main">
           @RenderBody()
        </main>

    </div>

    <script src="~/js/sidebar.js" asp-append-version="true"></script>
</body>
</html>